# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
.env
.venv/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.coverage
.tox/
.pytest_cache/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Editor directories and files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS files
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints

# Logs
*.log

# Wheels
pip-wheel-metadata/

# mypy
.mypy_cache/

# env
ENV/
env/

# Coverage
coverage.xml

# Misc
*.sqlite3

# Keep requirements and README
!requirements.txt
!README.md
